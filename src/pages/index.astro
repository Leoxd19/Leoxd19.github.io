---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Leo Gardberg">
  <div class="heroContent">
    <h1 class="name">Leo Gardberg</h1>
    <p>currently @ <a href="https://furhatrobotics.com" target="_blank" class="logoLink"><img src="/furhatlogo.png" alt="Furhat Robotics" class="logo" /></a> — working with social robots</p>
    <dotlottie-wc src="/animation.lottie" autoplay loop class="mascot"></dotlottie-wc>
    <span class="soon">// more soon</span>
  </div>
</BaseLayout>

<style>
  .heroContent {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .name {
    font-size: 1.8rem;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  .logoLink {
    line-height: 0;
  }

  .logo {
    display: inline-block;
    vertical-align: middle;
    width: 140px;
    height: auto;
    opacity: 0.9;
    filter: invert(1);
  }

  .mascot {
    width: min(380px, 90vw);
    aspect-ratio: 19 / 10;
  }

  .soon {
    font-size: 0.8rem;
    color: #e8e8e8;
    letter-spacing: 0.08em;
  }

  @media (max-width: 480px) {
    .heroContent {
      gap: 1rem;
    }

    .name {
      font-size: 1.2rem;
    }

    .logo {
      width: 90px;
    }

    .mascot {
      width: min(300px, 80vw);
    }

    .soon {
      font-size: 0.7rem;
    }
  }
</style>
