---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Leo Gardberg">
  <div class="heroContent">
    <h1 class="name">Leo Gardberg</h1>
    <p>currently @ <a href="https://furhatrobotics.com" target="_blank" class="logoLink"><img src="/furhatlogo.png" alt="Furhat Robotics" class="logo" /></a> working with social robots</p>
  </div>
</BaseLayout>

<style>
  .heroContent {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .name {
    font-size: 1.8rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
  }

  .logoLink {
    line-height: 0;
  }

  .logo {
    display: inline-block;
    vertical-align: middle;
    width: 140px;
    height: auto;
    opacity: 0.9;
    filter: invert(1);
  }
</style>
